                });
                
                stateManager.set('testSubscription', 'subscribeTest');
                logToSection('state-log', `Subscription test: ${subscriptionTriggered ? 'PASS' : 'FAIL'}`);
                
                // Test state updates
                stateManager.update({
                    testUpdate1: 'value1',
