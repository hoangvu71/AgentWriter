@dataclass
class Plot:
    """Plot entity - matches actual plots table structure"""
    id: Optional[str] = None  # UUID
    session_id: str = ""  # UUID - references sessions.id
    user_id: str = ""  # UUID - references users.id
    title: str = ""  # TEXT
