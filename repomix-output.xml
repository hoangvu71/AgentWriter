            } catch (error) {
                logResult('state-result', 'Error: ' + error.message, true);
                logToSection('state-log', 'Error: ' + error.message);
            }
        }
        
        function testUIManager() {
            try {
                // Test element getting
                const input = uiManager.getElement('test-input');
                logToSection('ui-log', `Element retrieval: ${input ? 'PASS' : 'FAIL'}`);
                
                // Test content operations
                uiManager.setContent('ui-result', 'UI Manager Test Active');
                const content = uiManager.getContent('test-input');
                logToSection('ui-log', `Content operations: PASS`);
                
                // Test visibility operations
                uiManager.setVisible('ui-log', true);
                logToSection('ui-log', 'Visibility operations: PASS');
                
                // Test dropdown operations (if elements exist)
                const testData = [
                    { id: 1, name: 'Option 1' },
                    { id: 2, name: 'Option 2' }
                ];
                // Note: This will fail gracefully if no dropdown exists
                
                logResult('ui-result', 'UI Manager working correctly');
                
            } catch (error) {
                logResult('ui-result', 'Error: ' + error.message, true);
                logToSection('ui-log', 'Error: ' + error.message);
            }
        }
        
        function testAgentSystem() {
            try {
                const selectedAgent = document.getElementById('agent-select').value;
                
                // Test agent config retrieval
                const config = agentManager.getAgentConfig(selectedAgent);
                logToSection('agent-log', `Agent config retrieved: ${config.name}`);
                
                // Test agent detection
                const mockData = { content: `This is a ${selectedAgent} message`, agent: selectedAgent };
                const detected = agentManager.detectAgentFromMessage(mockData);
                logToSection('agent-log', `Agent detection: ${detected}`);
                
                // Test workflow detection
                const workflowContent = 'orchestrator routing to plot_then_author workflow';
                const isWorkflow = agentManager.isOrchestratorWorkflow(workflowContent);
                logToSection('agent-log', `Workflow detection: ${isWorkflow ? 'PASS' : 'FAIL'}`);
                
                // Test dynamic styling
                agentManager.addAgentStyle(selectedAgent);
                logToSection('agent-log', 'Dynamic styling applied');
                
                logResult('agent-result', 'Agent system working correctly');
                
            } catch (error) {
                logResult('agent-result', 'Error: ' + error.message, true);
                logToSection('agent-log', 'Error: ' + error.message);
            }
        }
        
        function testWebSocketService() {
            try {
                // Test connection state
                const state = webSocketService.getConnectionState();
                logToSection('websocket-log', `Connection state: ${state}`);
                
                // Test session info
                const sessionInfo = webSocketService.getSessionInfo();
                logToSection('websocket-log', `Session info: ${JSON.stringify(sessionInfo)}`);
                
                // Test message handler registration
                webSocketService.onMessage('test', (data) => {
                    logToSection('websocket-log', 'Test message handler triggered');
                });
                logToSection('websocket-log', 'Message handler registered');
                
                logResult('websocket-result', 'WebSocket service structure working correctly');
                
            } catch (error) {
                logResult('websocket-result', 'Error: ' + error.message, true);
                logToSection('websocket-log', 'Error: ' + error.message);
            }
        }
        
        function testAPIService() {
            try {
                // Test method existence
                const methods = ['fetchJSON', 'loadModels', 'loadParameters', 'loadContent'];
                const results = methods.map(method => {
                    const exists = typeof apiService[method] === 'function';
                    return `${method}: ${exists ? 'EXISTS' : 'MISSING'}`;
                });
                
                logToSection('api-log', results.join(', '));
                
                // Test base configuration
                logToSection('api-log', `Base URL: ${apiService.baseURL}`);
                
                logResult('api-result', 'API service structure working correctly');
                
            } catch (error) {
                logResult('api-result', 'Error: ' + error.message, true);
                logToSection('api-log', 'Error: ' + error.message);
            }
        }
        
        function testFullIntegration() {
            try {
                logToSection('integration-log', 'Starting full integration test...');
                
                // Test enhanced chat app initialization
                const isInitialized = enhancedChatApp.initialized;
                logToSection('integration-log', `Enhanced chat app initialized: ${isInitialized}`);
                
                // Test module interconnection
                stateManager.set('testIntegration', 'integrationValue');
                const retrieved = stateManager.get('testIntegration');
                logToSection('integration-log', `State <-> Integration: ${retrieved === 'integrationValue' ? 'PASS' : 'FAIL'}`);
                
                // Test theme integration
                const currentTheme = themeManager.getCurrentTheme();
                logToSection('integration-log', `Theme integration: ${currentTheme}`);
                
                // Test agent system integration
                const agentConfig = agentManager.getAgentConfig('orchestrator');
                logToSection('integration-log', `Agent integration: ${agentConfig.name}`);
                
                logToSection('integration-log', 'All integration tests completed');
                logResult('integration-result', 'Full integration working correctly');
                
            } catch (error) {
                logResult('integration-result', 'Error: ' + error.message, true);
                logToSection('integration-log', 'Error: ' + error.message);
            }
        }
        
        // Auto-run initial tests
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(() => {
                testModuleLoading();
            }, 500);
        });
    </script>
</body>
