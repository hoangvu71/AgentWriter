            // Initialize dynamic agent styles
            function initializeAgentStyles() {
                const styleSheet = document.createElement('style');
                styleSheet.id = 'dynamic-agent-styles';
                
                let css = `
                    .agent-header {
                        display: flex;
                        align-items: center;
                        gap: 0.75rem;
