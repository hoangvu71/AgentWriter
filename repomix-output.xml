                    return a & a;
                }, 0);
                
                const hue = Math.abs(hash) % 360;
                const saturation = 60 + (Math.abs(hash) % 30); // 60-90%
                const lightness = 45 + (Math.abs(hash) % 20);  // 45-65%
                
                return [
                    `hsl(${hue}, ${saturation}%, ${lightness}%)`,
