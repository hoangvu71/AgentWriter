    <script src="static/js/modules/theme.js"></script>
    <script src="static/js/chat-enhanced.js"></script>
    
    <script>
        // Test functions
        function logResult(sectionId, message, isError = false) {
            const element = document.getElementById(sectionId);
            if (element) {
                element.className = isError ? 'error' : 'success';
                element.textContent = message;
            }
        }
        
        function logToSection(logId, message) {
            const log = document.getElementById(logId);
            if (log) {
                log.textContent += new Date().toLocaleTimeString() + ': ' + message + '\n';
            }
        }
        
        function testModuleLoading() {
            const results = [];
            
            try {
                if (typeof apiService !== 'undefined') {
                    results.push('✓ API Service loaded');
                } else {
                    results.push('✗ API Service failed to load');
                }
                
                if (typeof webSocketService !== 'undefined') {
                    results.push('✓ WebSocket Service loaded');
                } else {
                    results.push('✗ WebSocket Service failed to load');
                }
                
                if (typeof stateManager !== 'undefined') {
                    results.push('✓ State Manager loaded');
                } else {
                    results.push('✗ State Manager failed to load');
                }
                
                if (typeof uiManager !== 'undefined') {
                    results.push('✓ UI Manager loaded');
                } else {
                    results.push('✗ UI Manager failed to load');
                }
                
                if (typeof agentManager !== 'undefined') {
                    results.push('✓ Agent Manager loaded');
                } else {
                    results.push('✗ Agent Manager failed to load');
