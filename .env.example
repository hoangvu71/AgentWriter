# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
GOOGLE_GENAI_USE_VERTEXAI=true

# Database Configuration
DATABASE_MODE=sqlite  # Options: supabase, sqlite
SQLITE_DB_PATH=development.db  # Path for SQLite database file

# Supabase Configuration (for production use)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
# Database password for CLI migrations (get from Supabase Dashboard → Settings → Database)
SUPABASE_DB_PASSWORD=your-database-password